# API keys are stored in the browser's localStorage, not in files.
# Use _tmSetApiKey() from the browser console to set them:
#   _tmSetApiKey('XAI_API_KEY',       'xai-...')
#   _tmSetApiKey('ANTHROPIC_API_KEY', 'sk-ant-...')
#   _tmSetApiKey('OPENAI_API_KEY',    'sk-...')
#   _tmSetApiKey('SUPABASE_URL',      'https://...')
#   _tmSetApiKey('SUPABASE_ANON_KEY', 'eyJh...')
#
# For CI/CD, inject keys into localStorage via your deployment script.
